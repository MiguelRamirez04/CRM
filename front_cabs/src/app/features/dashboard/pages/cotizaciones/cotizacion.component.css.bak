/* Contenedor principal */
.container {
  min-height: 100vh;
  background-color: #f9fafb;
  padding: 1.25rem;
}

.form-wrapper {
  max-width: 1400px;
  margin: 0 auto;
  background-color: white;
  border-radius: 20px;
  box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

/* Encabezado */
.header {
  background-color: white;
  padding: 1.25rem 1.875rem;
  border-bottom: 1px solid #d1d5db;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}

.header-title {
  font-weight: 600;
  font-size: 1.5rem;
  margin-bottom: 0.25rem;
}

.header-id {
  font-size: 0.875rem;
  color: #6b7280;
}

.date-input-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.date-input-wrapper label {
  font-size: 0.875rem;
  margin-bottom: 0.25rem;
}

.date-input {
  padding: 0.5rem 0.75rem;
  border: 1px solid #d1d5db;
  border-radius: 0.5rem;
  font-size: 0.875rem;
  width: auto;
}

.date-input:focus {
  outline: none;
  border-color: #34428F;
}

/* Secciones del formulario */
.form-section {
  padding: 1.5rem 1.875rem;
  border-bottom: 1px solid #e5e7eb;
}

.section-title {
  font-weight: 600;
  margin-bottom: 1rem;
  font-size: 1.125rem;
}

/* Inputs y controles */
.form-row {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 1rem;
}

.form-group {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 200px;
}

.form-group.full-width {
  width: 100%;
}

.form-label {
  font-weight: 500;
  font-size: 0.875rem;
  margin-bottom: 0.25rem;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 0.5rem 0.75rem;
  border: 1px solid #d1d5db;
  border-radius: 0.5rem;
  font-size: 0.875rem;
}

.form-input:focus,
.form-textarea:focus {
  outline: none;
  border-color: #34428F;
}

.form-input.error {
  border-color: #ef4444;
}

.form-textarea {
  resize: vertical;
  min-height: 38px;
}

/* Botones de tipo de cliente */
.client-type-buttons {
  display: flex;
  gap: 0.5rem;
}

.client-type-btn {
  flex: 1;
  padding: 0.5rem 0.75rem;
  border: 1px solid #d1d5db;
  border-radius: 0.5rem;
  cursor: pointer;
  font-size: 0.875rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.25rem;
  transition: all 0.2s;
  background-color: white;
  color: #374151;
}

.client-type-btn:hover {
  border-color: #1f2a70;
}

.client-type-btn.active {
  background-color: #34428F;
  color: white;
  border-color: #34428F;
}

.client-type-btn svg {
  width: 1rem;
  height: 1rem;
}

/* Badge de estado */
.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.5rem 1rem;
  border-radius: 20px;
  font-weight: 700;
  font-size: 0.875rem;
  background-color: #22C55E;
  color: white;
}

.status-badge svg {
  width: 1rem;
  height: 1rem;
  margin-right: 0.25rem;
}

/* Tabla de productos */
.products-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.products-header h5 {
  font-weight: 600;
  font-size: 1.125rem;
  margin: 0;
}

.btn-add-product {
  padding: 0.25rem 0.75rem;
  background-color: #e9fbe9;
  border: 1px solid #38c172;
  color: #38c172;
  border-radius: 10px;
  font-size: 0.875rem;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-add-product:hover {
  background-color: white;
  border-width: 2px;
  transform: translateY(-2px);
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
}

.btn-add-product svg {
  width: 1.5rem;
  height: 1.5rem;
}

.table-wrapper {
  overflow-x: auto;
}

.products-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 800px;
}

.products-table thead {
  background-color: #FAFAFA;
}

.products-table th {
  padding: 0.75rem;
  text-align: left;
  font-weight: 600;
  border-bottom: 2px solid #e5e7eb;
}

.products-table td {
  padding: 0.75rem;
  border-bottom: 1px solid #e5e7eb;
}

.product-input-group {
  display: flex;
}

.product-search-btn {
  background-color: #34428F;
  border: 1px solid #34428F;
  border-radius: 0.5rem 0 0 0.5rem;
  padding: 0.5rem 0.75rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-search-btn svg {
  width: 1.25rem;
  height: 1.25rem;
  color: white;
}

.product-input-group input {
  border-left: 0;
  border-radius: 0 0.5rem 0.5rem 0;
}

.btn-delete-product {
  padding: 0.25rem 0.75rem;
  border: 1px solid #e3342f;
  color: #e3342f;
  background-color: white;
  border-radius: 0.5rem;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-delete-product:hover {
  background-color: #e3342f;
  color: white;
  transform: translateY(-2px);
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
}

/* Totales */
.totals-box {
  background-color: #FAFAFA;
  border-radius: 15px;
  border: 1px solid #e5e7eb;
  padding: 1rem;
  max-width: 300px;
  margin-left: auto;
  margin-top: 1.25rem;
}

.totals-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 0.5rem;
}

.totals-divider {
  border: 0;
  height: 1px;
  background-color: #34428F;
  margin: 0.75rem 0;
}

.totals-total {
  display: flex;
  justify-content: space-between;
  color: #34428F;
  font-weight: 700;
  font-size: 1.125rem;
}

.commission-group {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: 1rem;
}

.commission-group label {
  font-size: 0.875rem;
}

.commission-input-wrapper {
  display: flex;
  align-items: center;
}

.commission-input {
  width: 70px;
  padding: 0.375rem 0.5rem;
  text-align: right;
  border: 1px solid #d1d5db;
  border-radius: 0.5rem 0 0 0.5rem;
  font-size: 0.875rem;
}

.commission-input:focus {
  outline: none;
  border-color: #34428F;
}

.commission-symbol {
  padding: 0.25rem 0.875rem;
  background-color: #e9ecef;
  border: 1px solid #d1d5db;
  border-left: 0;
  border-radius: 0 0.5rem 0.5rem 0;
}

/* Footer */
.footer {
  padding: 1.25rem 1.875rem;
  background-color: #f9f9f9;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1.25rem;
  border-top: 1px solid #e5e7eb;
}

.footer-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.btn-action {
  padding: 0.5rem 1.25rem;
  border: 0;
  border-radius: 20px;
  font-weight: 500;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.875rem;
  transition: all 0.2s;
}

.btn-action svg {
  width: 1.25rem;
  height: 1.25rem;
}

.btn-action:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
}

.btn-save {
  background-color: #34428F;
  color: white;
}

.btn-save:hover {
  background-color: white;
  color: #34428F;
  border: 2px solid #34428F;
}

.btn-send {
  background-color: #A78BFA;
  color: white;
  border: 2px solid transparent;
}

.btn-send:hover {
  background-color: white;
  color: #A78BFA;
  border-color: #A78BFA;
}

.btn-pdf {
  background-color: #35D9FD;
  color: white;
}

.btn-pdf:hover {
  background-color: white;
  color: #35D9FD;
  border: 2px solid #35D9FD;
}

.status-info {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-box {
  background-color: #fff8e1;
  border-radius: 20px;
  padding: 0.5rem 1.25rem;
  color: #ffb300;
  font-weight: 700;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  margin-bottom: 0.5rem;
}

.status-details {
  font-size: 0.875rem;
  color: #6b7280;
}

/* Responsive */
@media (max-width: 768px) {
  .header,
  .footer {
    flex-direction: column;
    align-items: stretch;
  }
  
  .date-input-wrapper {
    align-items: stretch;
  }
  
  .form-group {
    min-width: 100%;
  }
  
  .status-info {
    width: 100%;
  }
}