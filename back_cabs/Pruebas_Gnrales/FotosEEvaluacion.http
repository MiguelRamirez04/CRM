# =====================================================================================
# VARIABLES DE ENTORNO
# =====================================================================================
@back_cabs_HostAddress = http://localhost:5176
# ⚠️ IMPORTANTE: Reemplaza este token por uno válido y vigente antes de ejecutar.
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJuYW1laWQiOiIxIiwiZW1haWwiOiJhZG1pbkBnbWFpw7EuY29tIiwidW5pcXVlX25hbWUiOiJhZG1pbiBhZG1pbiIsInJvbGUiOiJBRE1JTklTVFJBQ0lPTiIsIm5iZiI6MTc2MDcyMDgyOSwiZXhwIjoxNzYwNzIyNjI5LCJpYXQiOjE3NjA3MjA4MjksImlzcyI6IkNSTS1BUEktREVWIiwiYXVkIjoiQ1JNLUNsaWVudC1ERVYifQ.5Wfg73cXZAja9VzEpmYvOqNxrO1o2eemwktaXwoJ4Ss

# IDs para pruebas
@fotoId = 1
@fotoIdInexistente = 9999
@detalleIdParaFoto = 1


# =====================================================================================
# PRUEBAS DE API - MÓDULO DE FOTOS DE EVALUACIÓN
# =====================================================================================
#
# BASE URL: {{back_cabs_HostAddress}}/api/FotosEvaluacion
#
# ENDPOINTS DISPONIBLES:
# ┌────────────────────────────────────────────────────────────────────────────────────────┐
# │ VERBO  | RUTA                                  | DESCRIPCIÓN                            │
# ├────────────────────────────────────────────────────────────────────────────────────────┤
# │ POST   | /api/FotosEvaluacion                  | Subir una nueva foto de evaluación.    │
# │ GET    | /api/FotosEvaluacion                  | Obtener todas las fotos de evaluación. │
# │ GET    | /api/FotosEvaluacion/{id}             | Obtener los detalles de una foto por ID.│
# │ PUT    | /api/FotosEvaluacion/{id}             | Actualizar la descripción de una foto. │
# │ DELETE | /api/FotosEvaluacion/{id}             | Eliminar una foto.                     │
# │ GET    | /api/FotosEvaluacion/{id}/download    | Descargar el archivo de una foto.      │
# └────────────────────────────────────────────────────────────────────────────────────────┘
# =====================================================================================

###
# ============================================================================
# 1. POST - SUBIR UNA NUEVA FOTO DE EVALUACIÓN
# ============================================================================

# ----------------------------------------------------------------------------
# 1.1 Prueba de Éxito: Subir una foto con todos los datos requeridos
# ----------------------------------------------------------------------------
# Nota: La subida de archivos usa 'multipart/form-data', no 'application/json'.
#       Asegúrate de que la ruta al archivo en 'archivo' sea correcta.
# Respuesta esperada: 201 Created
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/FotosEvaluacion
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW
Authorization: Bearer {{token}}

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="detalleId"

{{detalleIdParaFoto}}
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="tipo"

"Evidencia Inicial"
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="descripcion"

"Foto del estado del vehículo antes del servicio."
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="archivo"; filename="evidencia1.jpg"
Content-Type: image/jpeg

< C:/ruta/a/tu/imagen/evidencia1.jpg

------WebKitFormBoundary7MA4YWxkTrZu0gW--


###
# ============================================================================
# 2. GET - OBTENER TODAS LAS FOTOS
# ============================================================================
GET {{back_cabs_HostAddress}}/api/FotosEvaluacion
Accept: application/json
Authorization: Bearer {{token}}


###
# ============================================================================
# 3. GET - OBTENER FOTO POR ID
# ============================================================================

# ----------------------------------------------------------------------------
# 3.1 Prueba de Éxito: Obtener detalles de una foto existente
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/FotosEvaluacion/{{fotoId}}
Accept: application/json
Authorization: Bearer {{token}}

# ----------------------------------------------------------------------------
# 3.2 Prueba de Error: Intento de obtener una foto con ID inexistente
# ----------------------------------------------------------------------------
# Respuesta esperada: 404 Not Found
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/FotosEvaluacion/{{fotoIdInexistente}}
Accept: application/json
Authorization: Bearer {{token}}


###
# ============================================================================
# 4. PUT - ACTUALIZAR DATOS DE UNA FOTO
# ============================================================================

# ----------------------------------------------------------------------------
# 4.1 Prueba de Éxito: Actualizar la descripción de una foto
# ----------------------------------------------------------------------------
# Respuesta esperada: 204 No Content (o 200 OK)
# ----------------------------------------------------------------------------
PUT {{back_cabs_HostAddress}}/api/FotosEvaluacion/{{fotoId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "tipo": "Evidencia Final",
    "descripcion": "Foto actualizada que muestra el trabajo completado."
}


###
# ============================================================================
# 5. DELETE - ELIMINAR UNA FOTO
# ============================================================================

# ----------------------------------------------------------------------------
# 5.1 Prueba de Éxito: Eliminar una foto con un ID existente
# ----------------------------------------------------------------------------
# Respuesta esperada: 204 No Content
# ----------------------------------------------------------------------------
DELETE {{back_cabs_HostAddress}}/api/FotosEvaluacion/{{fotoId}}
Authorization: Bearer {{token}}

# ----------------------------------------------------------------------------
# 5.2 Prueba de Error: Intento de eliminar una foto con ID inexistente
# ----------------------------------------------------------------------------
# Respuesta esperada: 404 Not Found
# ----------------------------------------------------------------------------
DELETE {{back_cabs_HostAddress}}/api/FotosEvaluacion/{{fotoIdInexistente}}
Authorization: Bearer {{token}}


###
# ============================================================================
# 6. GET - DESCARGAR EL ARCHIVO DE UNA FOTO
# ============================================================================

# ----------------------------------------------------------------------------
# 6.1 Prueba de Éxito: Descargar el archivo de una foto existente
# ----------------------------------------------------------------------------
# Nota: La respuesta no será JSON, será el archivo en sí (ej. una imagen).
# Respuesta esperada: 200 OK
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/FotosEvaluacion/{{fotoId}}/download
Authorization: Bearer {{token}}

# ----------------------------------------------------------------------------
# 6.2 Prueba de Error: Intentar descargar un archivo con ID inexistente
# ----------------------------------------------------------------------------
# Respuesta esperada: 404 Not Found
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/FotosEvaluacion/{{fotoIdInexistente}}/download
Authorization: Bearer {{token}}