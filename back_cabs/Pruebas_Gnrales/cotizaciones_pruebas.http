# =====================================================================================
# VARIABLES DE ENTORNO
# =====================================================================================
@back_cabs_HostAddress = http://localhost:5176
# ⚠️ IMPORTANTE: Reemplaza este token por uno válido y vigente antes de ejecutar.
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJuYW1laWQiOiIzIiwiZW1haWwiOiJhZG1pbkBleGFtcGxlLmNvbSIsInVuaXF1ZV9uYW1lIjoic3RyaW5nIHN0cmluZyIsInJvbGUiOiJBRE1JTklTVFJBQ0lPTiIsIm5iZiI6MTc2MTA3NjQ4OCwiZXhwIjoxNzYxMDc4Mjg4LCJpYXQiOjE3NjEwNzY0ODgsImlzcyI6IkNSTS1BUEktREVWIiwiYXVkIjoiQ1JNLUNsaWVudC1ERVYifQ.LGcP-dKFvPIowlk0MAvAWis34QYSj19Vx0YmwWDDlDo

# IDs para pruebas
@cotizacionId = 1
@cotizacionIdInexistente = 9999
@ordenId = 16
@ordenIdInexistente = 9999


# =====================================================================================
# PRUEBAS DE API - MÓDULO DE COTIZACIONES
# =====================================================================================
#
# BASE URL: {{back_cabs_HostAddress}}/api/Cotizaciones
#
# ENDPOINTS DISPONIBLES:
# ┌────────────────────────────────────────────────────────────────────────────────────────┐
# │ VERBO  | RUTA                              | DESCRIPCIÓN                             │
# ├────────────────────────────────────────────────────────────────────────────────────────┤
# │ POST   | /api/Cotizaciones                 | Crear una nueva cotización.             │
# │ GET    | /api/Cotizaciones                 | Obtener todas las cotizaciones.         │
# │ GET    | /api/Cotizaciones/{id}            | Obtener una cotización por su ID.       │
# │ GET    | /api/Cotizaciones/orden/{ordenId} | Obtener cotizaciones por OrdenId.       │
# │ GET    | /api/Cotizaciones/estado/{estado} | Obtener cotizaciones por estado.        │
# │ GET    | /api/Cotizaciones/cliente/{cliente}| Obtener cotizaciones por cliente.      │
# │ PUT    | /api/Cotizaciones/{id}            | Actualizar una cotización existente.    │
# │ DELETE | /api/Cotizaciones/{id}            | Eliminar una cotización por su ID.      │
# └────────────────────────────────────────────────────────────────────────────────────────┘
# =====================================================================================

### ============================================================================
# 1. POST - CREAR UNA NUEVA COTIZACIÓN
# ============================================================================

# ----------------------------------------------------------------------------
# 1.1 Prueba de Éxito: Crear una cotización con datos válidos completos
# ----------------------------------------------------------------------------
# Respuesta esperada: 201 Created
# Body esperado: CotizacionResponseDto con ID generado y Total calculado
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/Cotizaciones
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 16,
    "intakeLegacyId": null,
    "subtotal": 5000.00,
    "impuestosTotal": 800.00,
    "descuento": 200.00,
    "estado": "NUEVA",
    "observaciones": "Cotización para mantenimiento completo",
    "cliente": "Empresa ABC S.A. de C.V.",
    "rfc": "ABC123456789",
    "folio": "COT-2025-001",
    "descripcionServicio": "Servicio completo de mantenimiento preventivo incluyendo cambio de aceite, filtros y revisión general del vehículo.",
    "validezDias": 30
}

### ----------------------------------------------------------------------------
# 1.2 Prueba de Éxito: Crear una cotización mínima (solo campos requeridos)
# ----------------------------------------------------------------------------
# Respuesta esperada: 201 Created
# Body esperado: CotizacionResponseDto con valores por defecto
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/Cotizaciones
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 16,
    "subtotal": 2500.00,
    "estado": "NUEVA"
}

### ----------------------------------------------------------------------------
# 1.3 Prueba de Error: Datos inválidos (subtotal negativo)
# ----------------------------------------------------------------------------
# Respuesta esperada: 400 Bad Request
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/Cotizaciones
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 16,
    "subtotal": -100.00,
    "estado": "NUEVA"
}

### ----------------------------------------------------------------------------
# 1.4 Prueba de Error: Estado inválido
# ----------------------------------------------------------------------------
# Respuesta esperada: 400 Bad Request
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/Cotizaciones
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 16,
    "subtotal": 1000.00,
    "estado": "INVALIDO"
}

### ============================================================================
# 2. GET - OBTENER TODAS LAS COTIZACIONES
# ============================================================================

# ----------------------------------------------------------------------------
# 2.1 Prueba de Éxito: Obtener todas las cotizaciones
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# Body esperado: Array de CotizacionResponseDto ordenado por fecha descendente
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones
Authorization: Bearer {{token}}

### ============================================================================
# 3. GET - OBTENER COTIZACIÓN POR ID
# ============================================================================

# ----------------------------------------------------------------------------
# 3.1 Prueba de Éxito: Obtener cotización existente
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# Body esperado: CotizacionResponseDto completo
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones/{{cotizacionId}}
Authorization: Bearer {{token}}

### ----------------------------------------------------------------------------
# 3.2 Prueba de Error: Cotización inexistente
# ----------------------------------------------------------------------------
# Respuesta esperada: 404 Not Found
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones/{{cotizacionIdInexistente}}
Authorization: Bearer {{token}}

### ============================================================================
# 4. GET - OBTENER COTIZACIONES POR ORDEN ID
# ============================================================================

# ----------------------------------------------------------------------------
# 4.1 Prueba de Éxito: Obtener cotizaciones de una orden existente
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# Body esperado: Array de CotizacionResponseDto filtrado por ordenId
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones/orden/{{ordenId}}
Authorization: Bearer {{token}}

### ----------------------------------------------------------------------------
# 4.2 Prueba de Éxito: Orden sin cotizaciones
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# Body esperado: Array vacío []
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones/orden/{{ordenIdInexistente}}
Authorization: Bearer {{token}}

### ============================================================================
# 5. GET - OBTENER COTIZACIONES POR ESTADO
# ============================================================================

# ----------------------------------------------------------------------------
# 5.1 Prueba de Éxito: Obtener cotizaciones por estado NUEVA
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# Body esperado: Array de CotizacionResponseDto con estado "NUEVA"
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones/estado/NUEVA
Authorization: Bearer {{token}}

### ----------------------------------------------------------------------------
# 5.2 Prueba de Éxito: Estado sin cotizaciones
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# Body esperado: Array vacío []
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones/estado/APROBADA
Authorization: Bearer {{token}}

### ============================================================================
# 6. GET - OBTENER COTIZACIONES POR CLIENTE
# ============================================================================

# ----------------------------------------------------------------------------
# 6.1 Prueba de Éxito: Buscar cotizaciones por nombre de cliente
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# Body esperado: Array de CotizacionResponseDto que contienen el texto buscado
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones/cliente/Empresa
Authorization: Bearer {{token}}

### ----------------------------------------------------------------------------
# 6.2 Prueba de Éxito: Cliente no encontrado
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# Body esperado: Array vacío []
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones/cliente/ClienteInexistente
Authorization: Bearer {{token}}

### ============================================================================
# 7. PUT - ACTUALIZAR COTIZACIÓN
# ============================================================================

# ----------------------------------------------------------------------------
# 7.1 Prueba de Éxito: Actualizar cotización existente
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# Body esperado: CotizacionResponseDto actualizado con ActualizadoEn modificado
# ----------------------------------------------------------------------------
PUT {{back_cabs_HostAddress}}/api/Cotizaciones/{{cotizacionId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 16,
    "intakeLegacyId": null,
    "subtotal": 6000.00,
    "impuestosTotal": 960.00,
    "descuento": 300.00,
    "estado": "APROBADA",
    "observaciones": "Cotización actualizada y aprobada",
    "cliente": "Empresa ABC S.A. de C.V. (Actualizado)",
    "rfc": "ABC123456789",
    "folio": "COT-2025-001-REV",
    "descripcionServicio": "Servicio completo actualizado con revisión adicional.",
    "validezDias": 45
}

### ----------------------------------------------------------------------------
# 7.2 Prueba de Error: Actualizar cotización inexistente
# ----------------------------------------------------------------------------
# Respuesta esperada: 404 Not Found
# ----------------------------------------------------------------------------
PUT {{back_cabs_HostAddress}}/api/Cotizaciones/{{cotizacionIdInexistente}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 16,
    "subtotal": 1000.00,
    "estado": "NUEVA"
}

### ----------------------------------------------------------------------------
# 7.3 Prueba de Error: Datos inválidos en actualización
# ----------------------------------------------------------------------------
# Respuesta esperada: 400 Bad Request
# ----------------------------------------------------------------------------
PUT {{back_cabs_HostAddress}}/api/Cotizaciones/{{cotizacionId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 1,
    "subtotal": -500.00,
    "estado": "NUEVA"
}

### ============================================================================
# 8. DELETE - ELIMINAR COTIZACIÓN
# ============================================================================

# ----------------------------------------------------------------------------
# 8.1 Prueba de Éxito: Eliminar cotización existente
# ----------------------------------------------------------------------------
# Respuesta esperada: 204 No Content
# ----------------------------------------------------------------------------
DELETE {{back_cabs_HostAddress}}/api/Cotizaciones/{{cotizacionId}}
Authorization: Bearer {{token}}

### ----------------------------------------------------------------------------
# 8.2 Prueba de Error: Eliminar cotización inexistente
# ----------------------------------------------------------------------------
# Respuesta esperada: 404 Not Found
# ----------------------------------------------------------------------------
DELETE {{back_cabs_HostAddress}}/api/Cotizaciones/{{cotizacionIdInexistente}}
Authorization: Bearer {{token}}

### ============================================================================
# 9. PRUEBAS ADICIONALES - ESCENARIOS ESPECIALES
# ============================================================================

# ----------------------------------------------------------------------------
# 9.1 Prueba de Cálculo de Total: Verificar que Total = Subtotal + Impuestos - Descuento
# ----------------------------------------------------------------------------
# Crear cotización y verificar cálculo automático del Total
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/Cotizaciones
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 3,
    "subtotal": 10000.00,
    "impuestosTotal": 1600.00,
    "descuento": 1000.00,
    "estado": "NUEVA",
    "cliente": "Cliente de Prueba",
    "rfc": "TEST123456789",
    "folio": "TEST-001",
    "descripcionServicio": "Prueba de cálculo de total",
    "validezDias": 15
}

### ----------------------------------------------------------------------------
# 9.2 Prueba de Cálculo sin Descuento: Total = Subtotal + Impuestos
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/Cotizaciones
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 4,
    "subtotal": 8000.00,
    "impuestosTotal": 1280.00,
    "estado": "NUEVA",
    "cliente": "Cliente Sin Descuento",
    "rfc": "NODE123456789",
    "folio": "NODE-001",
    "descripcionServicio": "Prueba sin descuento aplicado",
    "validezDias": 20
}

### ----------------------------------------------------------------------------
# 9.3 Prueba de Campos Opcionales: RFC nulo, Folio nulo, etc.
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/Cotizaciones
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 5,
    "subtotal": 3000.00,
    "impuestosTotal": 480.00,
    "estado": "NUEVA",
    "observaciones": "Cotización con campos opcionales nulos",
    "descripcionServicio": "Servicio básico"
}

### ============================================================================
# 10. PRUEBAS DE AUTORIZACIÓN
# ============================================================================

# ----------------------------------------------------------------------------
# 10.1 Prueba de Error: Sin token de autorización
# ----------------------------------------------------------------------------
# Respuesta esperada: 401 Unauthorized
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones

### ----------------------------------------------------------------------------
# 10.2 Prueba de Error: Token inválido
# ----------------------------------------------------------------------------
# Respuesta esperada: 401 Unauthorized
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Cotizaciones
Authorization: Bearer token_invalido