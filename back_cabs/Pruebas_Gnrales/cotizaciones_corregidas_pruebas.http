### ========================================
### 14. ACTUALIZAR COTIZACIÓN
### ========================================
### Reemplaza {id} con un ID válido
PUT {{baseUrl}}/Cotizaciones/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "documentoDeId": 1,
  "conceptoDocumentoId": 5,
  "clienteProveedorId": 10,
  "agenteId": 1,
  "documentoOrigenId": null,
  "serieDocumento": "COT",
  "folio": 1005,
  "fecha": "2025-11-12T19:23:40.554Z",
  "fechaVencimiento": "2025-12-12T19:23:40.554Z",
  "fechaEntregaRecepcion": "2025-11-15T19:23:40.554Z",
  "razonSocial": "Empresa ABC S.A. de C.V. ACTUALIZADA",
  "rfc": "ABC123456XYZ",
  "referencia": "REF-2025-001-UPD",
  "observaciones": "Cotización actualizada",
  "naturaleza": 1,
  "usaCliente": 1,
  "afectado": 0,
  "impreso": 1,
  "cancelado": 0,
