@back_cabs_HostAddress = http://localhost:5176

# =====================================================================================
# PRUEBAS DE REPARACIONES 
# =====================================================================================

### 1. CREAR REPARACIÓN (POST)
POST {{back_cabs_HostAddress}}/api/soporte/reparaciones
Content-Type: application/json

{
  "ordenId": 1,
  "tecnicoId": 2,
  "dispositivoTipo": "Laptop",
  "marca": "Dell",
  "modelo": "XPS-13",
  "accesoriosRecibidos": "Cargador",
  "descripcionFalla": "No enciende",
  "diagnostico": "Falla en la tarjeta madre",
  "solucionAplicada": "Reemplazo de la tarjeta madre",
  "resultado": "REPARADO",
  "causaIrreparable": null,
  "respaldoDatosAutorizado": true,
  "costoManoObra": 200.00,
  "costoRefaccionesCompra": 100.00,
  "costoRefaccionesPublico": 300.00,
  "costoTotalCompra": 300.00,
  "costoTotalPublico": 500.00,
  "margenEstimado": 200.00,
  "garantiaDias": 30,
  "fechaLlegada": "2025-10-22T10:00:00Z",
  "empezadoEn": "2025-10-22T11:00:00Z",
  "entregadoEn": "2025-10-22T16:00:00Z",
  "tipoEntrega": "DOMICILIO",
  "ubicacionAlmacenamiento": "Estante A1",
  "notas": "Reparación exitosa"
}

### 2. OBTENER TODAS LAS REPARACIONES (GET)
GET {{back_cabs_HostAddress}}/api/soporte/reparaciones
Accept: application/json

### 3. OBTENER REPARACIÓN POR ID (GET)
GET {{back_cabs_HostAddress}}/api/soporte/reparaciones/1
Accept: application/json

### 4. ACTUALIZAR REPARACIÓN (PUT)
PUT {{back_cabs_HostAddress}}/api/soporte/reparaciones/1
Content-Type: application/json

{
  "ordenId": 1,
  "tecnicoId": 2,
  "solucionAplicada": "Reemplazo de la tarjeta madre",
  "resultado": "REPARADO",
  "causaIrreparable": null,
  "costoManoObra": 250.00,
  "costoRefaccionesCompra": 120.00,
  "costoRefaccionesPublico": 350.00,
  "garantiaDias": 60,
  "empezadoEn": "2025-10-23T14:00:00Z",
  "entregadoEn": "2025-10-23T16:00:00Z",
  "tipoEntrega": "DOMICILIO",
  "notas": "Reparación exitosa"
}

### 5. CREAR COMPONENTE DE REPARACIÓN (POST)
POST {{back_cabs_HostAddress}}/api/soporte/reparaciones/componentes
Content-Type: application/json

{
  "reparacionId": 1,
  "componente": "Pantalla LCD",
  "cantidad": 1,
  "proveedor": "Proveedor de pantallas",
  "garantiaMeses": 12,
  "costoUnitarioCompra": 80.00,
  "costoUnitarioPublico": 150.00,
  "notas": "Pantalla nueva"
}

### 6. OBTENER TODOS LOS COMPONENTES DE REPARACIÓN (GET)
GET {{back_cabs_HostAddress}}/api/soporte/reparaciones/componentes
Accept: application/json

### 7. OBTENER COMPONENTE DE REPARACIÓN POR ID (GET)
GET {{back_cabs_HostAddress}}/api/soporte/reparaciones/componentes/1
Accept: application/json

### 8. ACTUALIZAR COMPONENTE DE REPARACIÓN (PUT)
PUT {{back_cabs_HostAddress}}/api/soporte/reparaciones/componentes/1
Content-Type: application/json

{
  "id": 1,
  "cantidad": 1,
  "garantiaMeses": 12,
  "costoUnitarioCompra": 90.00,
  "costoUnitarioPublico": 160.00,
  "notas": "Pantalla nueva (actualizado)"
}