# IDs para pruebas de endpoints
@clienteId = 1
@userId = 1

# IDs para pruebas de recursos no existentes (404 Not Found)
@clienteIdInexistente = 9999
@userIdInexistente = 9999


# =====================================================================================
# PRUEBAS DE API - MÓDULO DE DIAGNÓSTICO
# =====================================================================================
#
# BASE URL: {{back_cabs_HostAddress}}/api/Diagnostic
#
# ENDPOINTS DISPONIBLES:
# ┌────────────────────────────────────────────────────────────────────────────────────────┐
# │ VERBO  | RUTA                                  | DESCRIPCIÓN                            │
# ├────────────────────────────────────────────────────────────────────────────────────────┤
# │ GET    | /api/Diagnostic/estructura-clientes   | Obtiene una estructura de clientes.    │
# │ GET    | /api/Diagnostic/validar-cliente/{id}  | Valida si un cliente existe.           │
# │ GET    | /api/Diagnostic/validar-usuario/{id}  | Valida si un usuario existe.           │
# │ GET    | /api/Diagnostic/test-legacy-client/{id} | Realiza un test en un cliente legacy.  │
# └────────────────────────────────────────────────────────────────────────────────────────┘
# =====================================================================================

###
# ============================================================================
# 1. GET - OBTENER ESTRUCTURA DE CLIENTES
# Endpoint: /api/Diagnostic/estructura-clientes
# ============================================================================

# ----------------------------------------------------------------------------
# 1.1 Prueba de Éxito: Obtener la estructura correctamente
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Diagnostic/estructura-clientes
Accept: application/json
Authorization: Bearer {{token}}

# ----------------------------------------------------------------------------
# 1.2 Prueba de Error: Intento sin autenticación
# ----------------------------------------------------------------------------
# Respuesta esperada: 401 Unauthorized
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Diagnostic/estructura-clientes
Accept: application/json


###
# ============================================================================
# 2. GET - VALIDAR CLIENTE POR ID
# Endpoint: /api/Diagnostic/validar-cliente/{clienteId}
# ============================================================================

# ----------------------------------------------------------------------------
# 2.1 Prueba de Éxito: Validar un cliente existente
# ----------------------------------------------------------------------------
# Respuesta esperada: 200 OK
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Diagnostic/validar-cliente/{{clienteId}}
Accept: application/json
Authorization: Bearer {{token}}

# ----------------------------------------------------------------------------
# 2.2 Prueba de Error: Intentar validar un cliente con ID inexistente
# ----------------------------------------------------------------------------
# Respuesta esperada: 40