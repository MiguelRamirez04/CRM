# =====================================================================================
# PRUEBAS DE DIAGNOSTIC - CRM API
# =====================================================================================
# 
# MÓDULO: Recepción - Gestión de Órdenes de Trabajo
# BASE URL: http://localhost:5176/api/Diagnostic/
#
# ENDPOINTS DISPONIBLES:
# ┌──────────────────────────────────────────────────────────────────────────────────────────────┐
# │ GET    /api/Diagnostic/estructura-clientes           → Obtener todas las órdenes             │
# │ GET    /api/Diagnostic/validar-cliente/{clienteId}      → Obtener orden por ID                 │
# │ GET   /api/Diagnostic/validar-usuario/{userId}         → Crear nueva orden de trabajo         │
# │ GET    /api/Diagnostic/test-legacy-client/{clienteId}      → Actualizar orden existente           │
# └─────────────────────────────────────────────────────────────────────────┘
#
# NOTAS:
# - Reemplaza {{token}} con un JWT válido obtenido de /api/Auth/login
# - Las fechas deben estar en formato ISO 8601: "2025-10-05T09:00:00"
# - Los campos con "?" son opcionales (nullable)
#
# =====================================================================================

### ============================================================================
### 1. GET -  OBTENER LA INFORMACIÓN DE LOS CLIENTES
### ============================================================================
# Descripción: Toma la respuesta de la peticion y regresa eñ campo estructura
# Respuesta esperada: 200 OK con array de OrdenTrabajoResponseDto
# ============================================================================

GET {{back_cabs_HostAddress}}/api/Diagnostic/estructura-clientes
Accept: application/json
Authorization: Bearer {{token}}

### ============================================================================
### 2. GET -  OBTENER LA INFORMACIÓN DE LOS CLIENTES
### ============================================================================
# Descripción: Toma la respuesta de la peticion y regresa eñ campo estructura
# Respuesta esperada: 200 OK con array de OrdenTrabajoResponseDto
# ============================================================================

GET {{back_cabs_HostAddress}}/api/Diagnostic/estructura-clientes
Accept: application/json
Authorization: Bearer {{token}}

