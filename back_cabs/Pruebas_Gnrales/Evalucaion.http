# =====================================================================================
# VARIABLES DE ENTORNO
# =====================================================================================
@back_cabs_HostAddress = http://localhost:5176
# IMPORTANTE: Reemplaza este token por uno válido y vigente antes de ejecutar.
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJuYW1laWQiOiIxIiwiZW1haWwiOiJhZG1pbkBnbWFpw7EuY29tIiwidW5pcXVlX25hbWUiOiJhZG1pbiBhZG1pbiIsInJvbGUiOiJBRE1JTklTVFJBQ0lPTiIsIm5iZiI6MTc2MDcyMDgyOSwiZXhwIjoxNzYwNzIyNjI5LCJpYXQiOjE3NjA3MjA4MjksImlzcyI6IkNSTS1BUEktREVWIiwiYXVkIjoiQ1JNLUNsaWVudC1ERVYifQ.5Wfg73cXZAja9VzEpmYvOqNxrO1o2eemwktaXwoJ4Ss
# ID para pruebas de endpoints que requieren un recurso específico (GET por ID, PUT, DELETE)
@evaluacionId = 1
# ID para pruebas de recursos no existentes (404 Not Found)
@evaluacionIdInexistente = 9999


# =====================================================================================
# PRUEBAS DE API - MÓDULO DE EVALUACIÓN
# =====================================================================================
#
# BASE URL: {{back_cabs_HostAddress}}/api/Evaluacion
#
# ENDPOINTS DISPONIBLES:
# ┌────────────────────────────────────────────────────────────────────────────────────────┐
# │ VERBO  | RUTA                         | DESCRIPCIÓN                                │
# ├────────────────────────────────────────────────────────────────────────────────────────┤
# │ GET    | /api/Evaluacion              | Obtener todas las evaluaciones.            │
# │ POST   | /api/Evaluacion              | Crear una nueva evaluación.                │
# │ GET    | /api/Evaluacion/{id}         | Obtener una evaluación por su ID.          │
# │ PUT    | /api/Evaluacion/{id}         | Actualizar una evaluación existente.       │
# │ DELETE | /api/Evaluacion/{id}         | Eliminar una evaluación por su ID.         │
# └────────────────────────────────────────────────────────────────────────────────────────┘
#
# NOTAS:
# - Las fechas deben estar en formato ISO 8601: "AAAA-MM-DDTHH:mm:ss"
# - Los campos con "?" son opcionales (pueden ser nulos).
#
# =====================================================================================

###
# ============================================================================
# 1. POST - CREAR UNA NUEVA EVALUACIÓN
# ============================================================================

# ----------------------------------------------------------------------------
# 1.1 Prueba de Éxito: Crear una evaluación con datos válidos
# ----------------------------------------------------------------------------
# Descripción: Envía todos los datos requeridos para crear una evaluación.
# Respuesta esperada: 201 Created con el objeto de la evaluación creada.
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/Evaluacion
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 1,
    "ejecucionId": 1,
    "clienteId": 1,
    "evaluadorId": 1,
    "objetivo": "Verificar la correcta implementación del nuevo CRM.",
    "comentariosGenerales": "El cliente muestra satisfacción general con la implementación.",
    "scoreCalidadTotal": 95,
    "requiereSeguimiento": false,
    "seguimientoNotas": null,
    "evaluacionActualizada": "2025-10-17T10:00:00",
    "nuevaEvaluacion": null
}

# ----------------------------------------------------------------------------
# 1.2 Prueba de Error: Intento de crear sin autenticación
# ----------------------------------------------------------------------------
# Descripción: Llama al endpoint de creación sin el token de autorización.
# Respuesta esperada: 401 Unauthorized
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/Evaluacion
Content-Type: application/json

{
    "objetivo": "Esto no debería guardarse."
}


# ----------------------------------------------------------------------------
# 1.3 Prueba de Error: Intento de crear con datos inválidos (Bad Request)
# ----------------------------------------------------------------------------
# Descripción: Envía un cuerpo de solicitud sin un campo requerido (ej. "objetivo").
# Respuesta esperada: 400 Bad Request
# ----------------------------------------------------------------------------
POST {{back_cabs_HostAddress}}/api/Evaluacion
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 1,
    "ejecucionId": 1,
    "clienteId": 1,
    "evaluadorId": 1,
    "comentariosGenerales": "Falta el campo 'objetivo', debería fallar."
}


###
# ============================================================================
# 2. GET - OBTENER TODAS LAS EVALUACIONES
# ============================================================================

# ----------------------------------------------------------------------------
# 2.1 Prueba de Éxito: Obtener la lista de todas las evaluaciones
# ----------------------------------------------------------------------------
# Descripción: Obtiene el listado completo de evaluaciones existentes.
# Respuesta esperada: 200 OK con un array de evaluaciones.
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Evaluacion
Accept: application/json
Authorization: Bearer {{token}}

# ----------------------------------------------------------------------------
# 2.2 Prueba de Error: Intento de obtener la lista sin autenticación
# ----------------------------------------------------------------------------
# Descripción: Llama al endpoint sin el token de autorización.
# Respuesta esperada: 401 Unauthorized
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Evaluacion
Accept: application/json


###
# ============================================================================
# 3. GET - OBTENER EVALUACIÓN POR ID
# ============================================================================

# ----------------------------------------------------------------------------
# 3.1 Prueba de Éxito: Obtener una evaluación con un ID existente
# ----------------------------------------------------------------------------
# Descripción: Busca una evaluación específica usando su ID.
# Respuesta esperada: 200 OK con el objeto de la evaluación encontrada.
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Evaluacion/{{evaluacionId}}
Accept: application/json
Authorization: Bearer {{token}}

# ----------------------------------------------------------------------------
# 3.2 Prueba de Error: Intento de obtener una evaluación con ID inexistente
# ----------------------------------------------------------------------------
# Descripción: Busca una evaluación con un ID que no existe en la base de datos.
# Respuesta esperada: 404 Not Found
# ----------------------------------------------------------------------------
GET {{back_cabs_HostAddress}}/api/Evaluacion/{{evaluacionIdInexistente}}
Accept: application/json
Authorization: Bearer {{token}}


###
# ============================================================================
# 4. PUT - ACTUALIZAR UNA EVALUACIÓN EXISTENTE
# ============================================================================

# ----------------------------------------------------------------------------
# 4.1 Prueba de Éxito: Actualizar una evaluación con datos válidos
# ----------------------------------------------------------------------------
# Descripción: Modifica los campos de una evaluación existente.
# Respuesta esperada: 204 No Content (o 200 OK, dependiendo de tu implementación).
# ----------------------------------------------------------------------------
PUT {{back_cabs_HostAddress}}/api/Evaluacion/{{evaluacionId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "ordenId": 1,
    "ejecucionId": 1,
    "clienteId": 1,
    "evaluadorId": 1,
    "objetivo": "Objetivo actualizado post-revisión.",
    "comentariosGenerales": "Se añaden comentarios adicionales tras la junta de seguimiento.",
    "scoreCalidadTotal": 98,
    "requiereSeguimiento": true,
    "seguimientoNotas": "Agendar reunión de seguimiento para el próximo mes.",
    "evaluacionActualizada": "2025-10-20T12:30:00"
}

# ----------------------------------------------------------------------------
# 4.2 Prueba de Error: Intento de actualizar una evaluación con ID inexistente
# ----------------------------------------------------------------------------
# Descripción: Intenta actualizar una evaluación que no existe.
# Respuesta esperada: 404 Not Found
# ----------------------------------------------------------------------------
PUT {{back_cabs_HostAddress}}/api/Evaluacion/{{evaluacionIdInexistente}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "objetivo": "Esto no se guardará porque el ID no existe."
}

# ----------------------------------------------------------------------------
# 4.3 Prueba de Error: Intento de actualizar con datos inválidos (Bad Request)
# ----------------------------------------------------------------------------
# Descripción: Envía un cuerpo de solicitud con un tipo de dato incorrecto.
# Respuesta esperada: 400 Bad Request
# ----------------------------------------------------------------------------
PUT {{back_cabs_HostAddress}}/api/Evaluacion/{{evaluacionId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "scoreCalidadTotal": "esto-es-un-string-no-un-numero"
}


###
# ============================================================================
# 5. DELETE - ELIMINAR UNA EVALUACIÓN
# ============================================================================

# ----------------------------------------------------------------------------
# 5.1 Prueba de Éxito: Eliminar una evaluación con un ID existente
# ----------------------------------------------------------------------------
# Descripción: Elimina una evaluación específica usando su ID.
# Respuesta esperada: 204 No Content (o 200 OK).
# ----------------------------------------------------------------------------
DELETE {{back_cabs_HostAddress}}/api/Evaluacion/{{evaluacionId}}
Authorization: Bearer {{token}}

# ----------------------------------------------------------------------------
# 5.2 Prueba de Error: Intento de eliminar una evaluación con ID inexistente
# ----------------------------------------------------------------------------
# Descripción: Intenta eliminar una evaluación que no existe.
# Respuesta esperada: 404 Not Found
# ----------------------------------------------------------------------------
DELETE {{back_cabs_HostAddress}}/api/Evaluacion/{{evaluacionIdInexistente}}
Authorization: Bearer {{token}}

# ----------------------------------------------------------------------------
# 5.3 Prueba de Error: Intento de eliminar sin autenticación
# ----------------------------------------------------------------------------
# Descripción: Llama al endpoint de eliminación sin el token de autorización.
# Respuesta esperada: 401 Unauthorized
# ----------------------------------------------------------------------------
DELETE {{back_cabs_HostAddress}}/api/Evaluacion/{{evaluacionId}}