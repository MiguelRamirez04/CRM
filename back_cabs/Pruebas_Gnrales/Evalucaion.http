# =====================================================================================
# PRUEBAS DE EVALUACION - CRM API
# =====================================================================================
# 
# MÓDULO: Recepción - Gestión de Órdenes de Trabajo
# BASE URL: http://localhost:5176/api/Diagnostic/
#
# ENDPOINTS DISPONIBLES:
# ┌──────────────────────────────────────────────────────────────────────────────────────────────┐
# │ GET    /api/Evaluacion/estructura-clientes           → Obtener todas las órdenes             │
# │ POST   /api/Evaluacion/      → Obtener orden por ID                 │
# │ GET    /api/Evaluacion/{id}         → Crear nueva orden de trabajo         │
# │ PUT    /api/Evaluacion/{id}      → Actualizar orden existente           │
# │ DELETE    /api/Evaluacion/{id}      → Actualizar orden existente           │
# └─────────────────────────────────────────────────────────────────────────┘
#
# NOTAS:
# - Reemplaza {{token}} con un JWT válido obtenido de /api/Auth/login
# - Las fechas deben estar en formato ISO 8601: "2025-10-05T09:00:00"
# - Los campos con "?" son opcionales (nullable)
#
# =====================================================================================

### ============================================================================
### 1. GET -  OBTENER LA INFORMACIÓN DE LOS CLIENTES
### ============================================================================
# Descripción: Toma la respuesta de la peticion y regresa eñ campo estructura
# Respuesta esperada: 200 OK con array de OrdenTrabajoResponseDto
# ============================================================================
GET {{back_cabs_HostAddress}}/api/Evaluacion
Accept: application/json
Authorization: Bearer {{token}}

### ============================================================================
### 1.1 GET -  OBTENER LA INFORMACIÓN DE LOS CLIENTES
### ============================================================================
# Descripción: Toma la respuesta de la peticion y regresa eñ campo estructura
# Respuesta esperada: 203 respuesta Non-Authoritative Information OrdenTrabajoResponseDto
# ============================================================================
GET {{back_cabs_HostAddress}}/api/Evalacion/
Accept: application/json 

### ============================================================================
### 2. GET -  OBTENER LA INFORMACIÓN DE LOS CLIENTES
### ============================================================================
# Descripción: Toma la respuesta de la peticion y regresa eñ campo estructura
# Respuesta esperada: 201 respuesta Non-Authoritative Information OrdenTrabajoResponseDto
# ============================================================================
POST {{back_cabs_HostAddress}}/api/Evalacion/
Accept: application/json
Authorization: Bearer {{token}}