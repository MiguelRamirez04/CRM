# {
#   "success": true,
#   "data": [...],
#   "count": 3,
#   "rol": "SOPORTE"
# }

### GET /tecnicos
# {
#   "success": true,
#   "data": [...], // SOPORTE + ADMINISTRACION
#   "count": 8
# }

### Error 400 (Rol inválido)
# {
#   "success": false,
#   "message": "Rol inválido. Roles válidos: SOPORTE, ADMINISTRACION, RECEPCION"
# }

### Error 401 (No autorizado)
# {
#   "message": "Token de acceso inválido o no proporcionado"
# }

### Error 403 (Forbidden - sin permisos)
# {
#   "message": "Forbidden"
# }
