@back_cabs_HostAddress = http://localhost:5176

# =====================================================================================
# PRUEBAS DE DETALLES DE EVALUACIÓN
# =====================================================================================

### 1. CREAR DETALLE DE EVALUACIÓN (POST)
POST {{back_cabs_HostAddress}}/api/EvaluacionDetalles
Content-Type: application/json

{
  "evaluacionId": 1,
  "fase": "Proceso",
  "descripcion": "Revisión inicial del equipo",
  "sugerencias": "Verificar el estado de la batería",
  "scoreFase": 80,
  "evidenciaNota": "Se adjuntan fotos del estado inicial",
  "lugar": "Oficina del cliente"
}

### 2. OBTENER DETALLE DE EVALUACIÓN POR ID (GET)
GET {{back_cabs_HostAddress}}/api/EvaluacionDetalles/1
Accept: application/json

### 3. ACTUALIZAR DETALLE DE EVALUACIÓN (PUT)
PUT {{back_cabs_HostAddress}}/api/EvaluacionDetalles/1
Content-Type: application/json

{
  "evaluacionId": 1,
  "fase": "DESPUES",
  "descripcion": "Revisión final del equipo",
  "sugerencias": "Entregar el equipo con el cargador",
  "scoreFase": 95,
  "evidenciaNota": "Se adjuntan fotos del estado final",
  "lugar": "Oficina del cliente"
}

### 4. ELIMINAR DETALLE DE EVALUACIÓN (DELETE)
DELETE {{back_cabs_HostAddress}}/api/EvaluacionDetalles/1

### 5. OBTENER DETALLES DE EVALUACIÓN POR EVALUACIÓN (GET)
GET {{back_cabs_HostAddress}}/api/EvaluacionDetalles/por-evaluacion/1
Accept: application/json